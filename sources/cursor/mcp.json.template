{
  "mcpServers": {
    "convex": {
      "command": "npx",
      "args": [
        "-y",
        "convex@latest",
        "mcp",
        "start"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "shadcn@latest",
        "mcp"
      ]
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "Ref": {
      "type": "http",
      "url": "https://api.ref.tools/mcp?apiKey={{REF_API_KEY}}",
      "headers": {}
    },
    "exa.ai": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={{EXA_API_KEY}}",
      "headers": {}
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{CONTEXT7_API_KEY}}"
      }
    }
  }
}
