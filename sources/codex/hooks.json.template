{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.codex/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Reading git state"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.codex/plugins/marketplaces/memsearch-plugins/plugins/codex/hooks/session-start.sh",
            "timeout": 30,
            "statusMessage": "Starting memsearch memory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{HOME}}/.codex/plugins/marketplaces/memsearch-plugins/plugins/codex/hooks/user-prompt-submit.sh",
            "timeout": 10,
            "statusMessage": "Checking memsearch memory"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.codex/hooks/check-backend-deploy.sh",
            "timeout": 10,
            "statusMessage": "Checking backend deploy guard"
          },
          {
            "type": "command",
            "command": "{{HOME}}/.codex/hooks/pre-publish-secret-scan.sh",
            "timeout": 10,
            "statusMessage": "Scanning outgoing git/GitHub text and denied commands"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.codex/hooks/format-python.sh",
            "timeout": 10,
            "statusMessage": "Formatting changed Python files"
          },
          {
            "type": "command",
            "command": "{{HOME}}/.codex/hooks/format-typescript.sh",
            "timeout": 10,
            "statusMessage": "Formatting changed TypeScript files"
          },
          {
            "type": "command",
            "command": "bash {{HOME}}/.codex/plugins/marketplaces/memsearch-plugins/plugins/codex/hooks/stop.sh",
            "timeout": 30,
            "statusMessage": "Saving memsearch memory"
          }
        ]
      }
    ]
  }
}
